# Region identity for this agent. Use non-sensitive labels only.
GSLB_REGION_ID=region-a

# Comma-separated region endpoints. Format: region_id=https://host/healthz
GSLB_REGION_ENDPOINTS=region-a=https://example-a.invalid/healthz,region-b=https://example-b.invalid/healthz,region-c=https://example-c.invalid/healthz

# Health check behavior.
GSLB_HEALTH_TIMEOUT=2s

# Cloudflare credentials are read from ENV at runtime.
# Do not commit real values.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_RECORD_ID=
CLOUDFLARE_RECORD_NAME=
